# Video Agent System — Secrets
# 복사: cp templates/secrets.env.template ~/.config/video-agents/secrets.env
# 권한: chmod 600 ~/.config/video-agents/secrets.env
# 이 파일은 절대 git에 커밋하지 말 것

# === SuperTone (음성 생성) ===
# 회원가입: https://supertone.ai (또는 https://console.supertoneapi.com)
# API 키 발급: 콘솔 > API > 발급
SUPERTONE_API_KEY=                  # REQUIRED

# 본인 보이스 ID — ⚠️ Sona Studio voice가 아니라 API용 cloned voice 필요
# 자동 등록: agents/supertone.md 의 onboarding 절차 참조
# (POST /v1/custom-voices/cloned-voice 로 audio 파일 등록 후 받은 voice_id)
SUPERTONE_VOICE_ID=                 # REQUIRED

# 기본 파라미터
# TODO: API에 직접 존재하지 않는 파라미터들. 클라이언트 후처리(ffmpeg 무음 삽입)로 구현 예정.
# 현재는 메타데이터로만 의미 있음. Supertone API가 받는 실재 파라미터는 voice_settings.speed (디폴트 1.05 — 격식체 발표 기준, 0.95 이하는 느리다는 피드백 반복).
# SUPERTONE_DEFAULT_SPEED=1.05
# SUPERTONE_DEFAULT_PAUSE_S=0.5

# === HeyGen (아바타 영상) ===
# 회원가입: https://heygen.com
# 아바타 생성: Studio > Avatars > Create (Photo Avatar 또는 Instant Avatar)
# ⚠️ Avatar V 지원 여부는 사전 체크 필수 (agents/avatar.md 참조)
HEYGEN_API_KEY=                     # REQUIRED
HEYGEN_AVATAR_ID=                   # REQUIRED

# === Pexels (b-roll 자동 소스 — 권장) ===
# 무료 키 발급: https://www.pexels.com/api/  (가입 즉시)
# 검색 API + 직접 mp4 다운로드 → 에이전트가 검색→다운→합성 자동. 무료 상업 라이선스.
PEXELS_API_KEY=

# === Envato Elements (프리미엄 b-roll — 수동) ===
# 회원가입: https://elements.envato.com (app.envato.com)
# ⚠️ 공개 검색 API 없음 → 에이전트가 검색 URL 제시, 사용자가 직접 다운로드/업로드.
# (videohive=Envato Market은 건당 구매라 워크플로 아님)
ENVATO_EMAIL=
ENVATO_API_KEY=

# === Remotion 프로젝트 경로 ===
REMOTION_PROJECT_ROOT=/Users/sam/Documents/remotion

# === Premiere Pro 실행 파일 경로 (자동화 시도용) ===
# ⚠️ 경로에 띄어쓰기 있어 따옴표 필수 — 없으면 shell `source` 시 에러
PREMIERE_PRO_PATH="/Applications/Adobe Premiere Pro 2026/Adobe Premiere Pro 2026.app"

# === Anthropic API (메인 에이전트가 Claude Code 외부에서 호출될 때) ===
# Claude Code 내에서만 쓸 거면 비워둬도 됨
ANTHROPIC_API_KEY=
